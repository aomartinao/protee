# Supabase Configuration (Optional - for cloud sync)
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Note: The app works fully offline without these.
# Cloud sync is optional for backing up data across devices.

# Supermemory Configuration (Optional - for long-term AI memory)
# Get your API key from https://console.supermemory.ai
VITE_SUPERMEMORY_API_KEY=your-supermemory-api-key

# For CLI scripts (indexing), also set these without VITE_ prefix:
# SUPERMEMORY_CC_API_KEY=your-supermemory-api-key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
